generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum RessourceState {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RessourceType {
  TEXT
  IMAGE
  VIDEO
  ACTIVITY
}

model User {
  id         String       @id @default(cuid())
  email      String       @unique
  firstname  String
  lastname   String
  password   String
  role       Role         @default(USER)
  ressources Ressource[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Ressource {
  id          String         @id @default(cuid())
  name        String
  description String
  shared      Boolean        @default(false)
  state       RessourceState @default(DRAFT)
  type        RessourceType  @default(TEXT)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
}
